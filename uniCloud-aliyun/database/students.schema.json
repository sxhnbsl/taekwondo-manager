{
	"bsonType": "object",
	"required": ["name", "parent_mobile"],
	"permission": {
		"read": "'admin' in auth.role || 'coach' in auth.role",
		"create": "'admin' in auth.role || 'coach' in auth.role",
		"update": "'admin' in auth.role || 'coach' in auth.role",
		"delete": "'admin' in auth.role"
	},
	"properties": {
		"_id": {
			"description": "学生ID"
		},
		"name": {
			"bsonType": "string",
			"description": "学生姓名",
			"trim": "both"
		},
		"gender": {
			"bsonType": "string",
			"description": "性别：male | female",
			"enum": ["male", "female"]
		},
		"birth_date": {
			"bsonType": "date",
			"description": "出生日期"
		},
		"level": {
			"bsonType": "string",
			"description": "跆拳道等级",
			"enum": ["white", "yellow", "blue", "red", "black"],
			"defaultValue": "white"
		},
		"parent_mobile": {
			"bsonType": "string",
			"description": "家长手机号",
			"pattern": "^1[3-9]\\d{9}$"
		},
		"parent_name": {
			"bsonType": "string",
			"description": "家长姓名"
		},
		"parent_user_id": {
			"bsonType": "string",
			"description": "关联的家长用户ID"
		},
		"avatar": {
			"bsonType": "string",
			"description": "学生头像URL"
		},
		"total_hours": {
			"bsonType": "int",
			"description": "总课时数",
			"defaultValue": 0
		},
		"used_hours": {
			"bsonType": "int",
			"description": "已用课时数",
			"defaultValue": 0
		},
		"remaining_hours": {
			"bsonType": "int",
			"description": "剩余课时数",
			"defaultValue": 0
		},
		"total_days": {
			"bsonType": "int",
			"description": "总天数课时",
			"defaultValue": 0
		},
		"used_days": {
			"bsonType": "int",
			"description": "已用天数课时",
			"defaultValue": 0
		},
		"remaining_days": {
			"bsonType": "int",
			"description": "剩余天数课时",
			"defaultValue": 0
		},
		"status": {
			"bsonType": "string",
			"description": "状态",
			"enum": ["active", "inactive", "graduated"],
			"defaultValue": "active"
		},
		"create_time": {
			"bsonType": "timestamp",
			"description": "创建时间",
			"forceDefaultValue": {
				"$env": "now"
			}
		},
		"update_time": {
			"bsonType": "timestamp",
			"description": "更新时间",
			"forceDefaultValue": {
				"$env": "now"
			}
		},
		"create_by": {
			"bsonType": "string",
			"description": "创建人ID"
		}
	}
}
